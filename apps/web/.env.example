# Data mode: 'mock' (default) or 'api'
# Set to 'api' to read from the local backend instead of prototype fixtures.
# The backend must be running at VITE_API_BASE_URL before enabling api mode.
VITE_DATA_MODE=mock

# Base URL of the local backend (only used when VITE_DATA_MODE=api)
VITE_API_BASE_URL=http://127.0.0.1:3000

# Enable prototype fixture switching via ?fixture= query param (for QA/dev)
VITE_ENABLE_PROTOTYPE_FIXTURES=false
