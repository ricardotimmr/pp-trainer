# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pp_trainer

# API server config (optional, defaults shown)
API_HOST=127.0.0.1
API_PORT=3000

# Allowed web origin for CORS (optional, default shown)
WEB_ORIGIN=http://127.0.0.1:5173

# Import storage path for uploaded FIT/GPX/TCX files (local dev)
IMPORT_STORAGE_PATH=./storage/imports

# Maximum file size for activity file uploads in MB (default: 20)
IMPORT_MAX_FILE_SIZE_MB=20
